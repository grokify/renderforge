{
  "name": "@renderforge/lit-navbar",
  "version": "0.1.0",
  "description": "Configurable navigation web component built with Lit",
  "type": "module",
  "main": "dist/lit-navbar.js",
  "types": "dist/lit-navbar.d.ts",
  "exports": {
    ".": {
      "import": "./dist/lit-navbar.js",
      "types": "./dist/lit-navbar.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "lit": "^3.1.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vite": "^5.2.0"
  },
  "keywords": [
    "web-components",
    "lit",
    "navigation",
    "navbar",
    "configurable",
    "renderforge"
  ],
  "author": "grokify",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/grokify/renderforge.git",
    "directory": "packages/lit/navbar"
  }
}
